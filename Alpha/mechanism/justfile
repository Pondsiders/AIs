# Mechanism dev recipes.
# Run from the mechanism/ directory: `just <recipe>`.

# List recipes.
default:
    @just --list

# Spin up dev Postgres, apply schema, refresh from production replica.
db-up:
    docker compose up -d
    @echo "(waiting for postgres to accept connections)"
    @until docker compose exec -T postgres pg_isready -U postgres >/dev/null 2>&1; do sleep 1; done
    uv run alembic upgrade head
    uv run copy-from-prod

# Tear down dev Postgres (preserves the named volume).
db-down:
    docker compose down

# Tear down dev Postgres AND wipe its data volume.
db-clean:
    docker compose down -v

# Run the test suite.
test:
    MODE=test uv run pytest
