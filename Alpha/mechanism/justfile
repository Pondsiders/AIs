# Mechanism dev recipes.
# Run from the mechanism/ directory: `just <recipe>`.

# List recipes.
default:
    @just --list

# Start the dev Postgres container.
db-up:
    docker compose up -d

# Stop the dev Postgres container (preserves the data volume).
db-down:
    docker compose down

# Wipe the data volume, bring Postgres up fresh, restore from a dump, stamp Alembic.
db-init dump:
    docker compose down -v
    docker compose up -d
    @echo "(waiting for postgres to accept connections)"
    @until docker compose exec -T postgres pg_isready -U postgres >/dev/null 2>&1; do sleep 1; done
    docker compose exec -T postgres pg_restore \
        --username=postgres \
        --dbname=postgres \
        --single-transaction \
        --no-owner \
        --no-acl \
        < {{dump}}
    docker compose exec -T postgres psql \
        --username=postgres \
        --dbname=postgres \
        --command="DROP TABLE IF EXISTS public.alembic_version"
    uv run alembic stamp head

# Run the test suite.
test:
    MODE=test uv run pytest
